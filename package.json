{
  "name": "app4cam-backend",
  "version": "5.7.0",
  "private": true,
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "node scripts/build/save-commit-hash-to-file.js && nest build",
    "format": "prettier --write --ignore-unknown .",
    "prepare": "husky",
    "start": "node scripts/build/save-commit-hash-to-file.js && cross-env NODE_ENV=development nest start",
    "start:dev": "node scripts/build/save-commit-hash-to-file.js && cross-env NODE_ENV=development nest start --watch",
    "start:debug": "node scripts/build/save-commit-hash-to-file.js && cross-env NODE_ENV=development nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --project e2e",
    "test:e2e:watch": "vitest --project e2e"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.5",
    "archiver": "7.0.1",
    "axios": "1.18.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "luxon": "3.7.2",
    "path": "0.12.7",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.28",
    "@types/archiver": "7.0.0",
    "@types/express": "5.0.6",
    "@types/luxon": "3.7.2",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.0",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vitest/eslint-plugin": "1.6.21",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "msw": "2.15.0",
    "node-mocks-http": "1.18.0",
    "prettier": "3.9.4",
    "prettier-plugin-sh": "0.18.1",
    "rimraf": "6.1.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint",
    "**/*": "prettier --write --ignore-unknown"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "GPL-3.0-or-later",
  "contributors": [
    {
      "name": "Adriano Gama",
      "email": "adriano.gama@list.lu"
    },
    {
      "name": "Daniel Waxweiler",
      "email": "daniel.waxweiler@list.lu"
    }
  ]
}
